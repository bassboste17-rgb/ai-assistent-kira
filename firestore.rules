rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // ადმინის შემოწმების ფუნქცია
    // ========================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        // შემოწმება admins კოლექციაში
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        // ან users კოლექციაში role == "admin"
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ========================================
    // USERS კოლექცია
    // ========================================
    match /users/{userId} {
      // ნებისმიერ ავტორიზებულ მომხმარებელს შეუძლია საკუთარი დოკუმენტის წაკითხვა
      allow read: if isOwner(userId);
      
      // მომხმარებელს შეუძლია შექმნას საკუთარი დოკუმენტი რეგისტრაციისას
      allow create: if isOwner(userId) && 
                       request.resource.data.role == "user"; // არ შეუძლია საკუთარ თავს admin მისცეს
      
      // მომხმარებელს შეუძლია განაახლოს საკუთარი მონაცემები (გარდა role-სა)
      allow update: if isOwner(userId) && 
                       request.resource.data.role == resource.data.role; // role არ იცვლება
      
      // მხოლოდ ადმინს შეუძლია წაშლა ან role-ის შეცვლა
      allow delete: if isAdmin();
      allow update: if isAdmin(); // ადმინს შეუძლია ყველაფრის შეცვლა
    }

    // ========================================
    // ADMINS კოლექცია
    // ========================================
    match /admins/{adminId} {
      // მხოლოდ წაკითხვა ავტორიზებული მომხმარებლებისთვის (ადმინის შემოწმებისთვის)
      allow read: if isAuthenticated();
      
      // მხოლოდ ადმინს შეუძლია ახალი ადმინის დამატება/წაშლა
      allow write: if isAdmin();
    }

    // ========================================
    // FULL TOURS კოლექცია
    // ========================================
    match /fullTours/{tourId} {
      // ყველას შეუძლია წაკითხვა (საჯარო კონტენტი)
      allow read: if true;
      
      // მხოლოდ ადმინს შეუძლია ჩაწერა/რედაქტირება/წაშლა
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // DAY TOURS კოლექცია
    // ========================================
    match /dayTours/{tourId} {
      // ყველას შეუძლია წაკითხვა (საჯარო კონტენტი)
      allow read: if true;
      
      // მხოლოდ ადმინს შეუძლია ჩაწერა/რედაქტირება/წაშლა
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // BOOKINGS კოლექცია (თუ დაგჭირდებათ)
    // ========================================
    match /bookings/{bookingId} {
      // მომხმარებელს შეუძლია საკუთარი ჯავშნების წაკითხვა
      allow read: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid;
      
      // მომხმარებელს შეუძლია ჯავშნის შექმნა საკუთარი userId-ით
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid;
      
      // ადმინს შეუძლია ყველაფრის წაკითხვა და რედაქტირება
      allow read, write: if isAdmin();
    }

    // ========================================
    // CONTACTS/INQUIRIES კოლექცია (თუ დაგჭირდებათ)
    // ========================================
    match /contacts/{contactId} {
      // ყველას შეუძლია შექმნა (კონტაქტ ფორმა)
      allow create: if true;
      
      // მხოლოდ ადმინს შეუძლია წაკითხვა და წაშლა
      allow read, update, delete: if isAdmin();
    }

    // ========================================
    // SETTINGS კოლექცია
    // ========================================
    match /settings/{settingId} {
      // ყველას შეუძლია წაკითხვა (საჯარო პარამეტრები)
      allow read: if true;
      
      // მხოლოდ ადმინს შეუძლია ჩაწერა
      allow write: if isAdmin();
    }

    // ========================================
    // ყველა სხვა კოლექცია - დაბლოკილია
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
